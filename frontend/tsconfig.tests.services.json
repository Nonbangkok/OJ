{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "isolatedModules": false,
    "types": ["node", "jest"]
  },
  "include": [
    "src/services/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/error.ts",
    "src/tests/services/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ]
}
