# This file serves as an example for the required .env file.
# Copy this file to .env and fill in the values.

# PostgreSQL Database Settings
POSTGRES_DB=oj_db
POSTGRES_USER=oj_user
POSTGRES_PASSWORD=your_strong_secret_password

# Backend Settings
# This is the secret key for express-session
SECRET_KEY=your_very_long_and_secret_key

# Frontend Settings
# This is passed to the React build process.
# The Nginx reverse proxy is configured to forward requests from this path to the backend.
REACT_APP_API_URL=/api

# Optional: use a DNS-only/origin endpoint for large admin uploads
# such as batch problem ZIPs or database imports. This avoids Cloudflare's
# proxied upload size limit on www.
# Example: https://upload.example.com/api
REACT_APP_LARGE_UPLOAD_API_URL=
